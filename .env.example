PORT=8105
# Optional overrides (persisted settings live in data/unificert-settings.json after Save)
#UNIFICERT_CERT_EMAIL=you@example.com
#UNIFICERT_CERT_HOSTS=unifi.example.com
#UNIFICERT_DNS_PROVIDER=cloudflare
# Gateway LAN IP only (no https://). UDM/UniFi OS SSH user is almost always:
#UNIFICERT_SSH_USER=root
#UNIFICERT_SSH_HOST=192.168.1.201
#UNIFICERT_SSH_KEY=/home/you/.ssh/id_ed25519
#UNIFICERT_SSH_PORT=22
# Small file from: ssh-keyscan $UNIFICERT_SSH_HOST | grep -v '^#' > ~/.ssh/known_hosts_unifi
#UNIFICERT_SSH_KNOWN_HOSTS=/home/you/.ssh/known_hosts_unifi
# Optional until ssh-copy-id: UniFi uses keyboard-interactive — quote value when it contains &.
#UNIFICERT_SSH_PASSWORD="your-console-ssh-password"
#UNIFICERT_CERT_DAYS=30

# UniFi Network API (optional — Wi‑Fi client log after a successful cert read):
# Loaded from ../unifi-smash-deck/.env when present (UNIFI_HOST, UNIFI_API_KEY, UNIFI_SITE).
# Set GOPROJECTS=/path/to/goprojects to use that sibling path.
